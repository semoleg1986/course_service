# course_service deploy profile
COURSE_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/course_service
COURSE_USE_INMEMORY=0
COURSE_AUTO_CREATE_SCHEMA=0
COURSE_AUTH_ISSUER=auth_service
COURSE_AUTH_AUDIENCE=platform_clients
COURSE_AUTH_JWKS_URL=http://auth_service:8000/.well-known/jwks.json
COURSE_SERVICE_TOKEN=__SET_IN_SECRETS__
