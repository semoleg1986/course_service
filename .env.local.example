# course_service env profiles
#
# Как использовать:
# 1) Скопируйте нужный профиль в .env
# 2) Запустите сервис

############################################################
# PROFILE: dev-inmemory
############################################################
# COURSE_USE_INMEMORY=1
# COURSE_DATABASE_URL=sqlite:///./course_service.db
# COURSE_AUTO_CREATE_SCHEMA=0
# COURSE_AUTH_ISSUER=auth_service
# COURSE_AUTH_JWKS_URL=http://localhost:8000/.well-known/jwks.json
# COURSE_SERVICE_TOKEN=dev-service-token

############################################################
# PROFILE: dev-postgres
############################################################
# COURSE_USE_INMEMORY=0
# COURSE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/course_service
# COURSE_AUTO_CREATE_SCHEMA=0
# COURSE_AUTH_ISSUER=auth_service
# COURSE_AUTH_JWKS_URL=http://localhost:8000/.well-known/jwks.json
# COURSE_SERVICE_TOKEN=dev-service-token

############################################################
# PROFILE: test-postgres
############################################################
# COURSE_USE_INMEMORY=0
# COURSE_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/course_service_test
# COURSE_AUTO_CREATE_SCHEMA=0
# COURSE_AUTH_ISSUER=auth_service
# COURSE_SERVICE_TOKEN=test-service-token
# COURSE_AUTH_JWKS_JSON={"keys":[{"kty":"OKP","crv":"Ed25519","x":"<base64url>","alg":"EdDSA","use":"sig","kid":"test-kid"}]}
